# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI GPT-4o (vision extraction)
OPENAI_API_KEY=

# Google Calendar OAuth (https://console.cloud.google.com/)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Long, random token for boss quick-upload bookmarklet URL.
# Any 32+ char random string. Rotate by regenerating + redeploying.
LEAD_INTAKE_UPLOAD_TOKEN=

# Public base URL (for Google OAuth redirect + calendar links)
# Set to https://<your-vercel-domain> in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000
