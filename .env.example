# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI GPT-4o (vision extraction)
OPENAI_API_KEY=

# Google Calendar OAuth (https://console.cloud.google.com/)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Long, random token for boss quick-upload bookmarklet URL.
# Any 32+ char random string. Rotate by regenerating + redeploying.
LEAD_INTAKE_UPLOAD_TOKEN=

# Public base URL (for Google OAuth redirect + calendar links)
# Set to https://<your-vercel-domain> in production.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Maps Distance Matrix (https://console.cloud.google.com/apis/library/distancematrix-backend.googleapis.com)
# Used by the scheduler to rank candidate slots by drive time from nearby jobs.
# Without this, /api/schedule/suggest returns 503 and the UI falls back to a
# simple time picker.
GOOGLE_MAPS_API_KEY=

# Web Push (generate with: npx web-push generate-vapid-keys --json).
# Without these, the "Enable Notifications" button shows as unavailable and
# uploads do not trigger any push. Public key is exposed to the client.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Apple Push Notification service (iOS shell). All four must be set for
# APNs fan-out to run — any missing value silently disables the native
# delivery path (web push still works). Generate the auth key in
# Apple Developer → Keys (see docs/IOS_SHELL_SETUP.md §5d).
#
# APNS_AUTH_KEY_P8: full PEM contents of the downloaded .p8 file,
#   including the BEGIN/END PRIVATE KEY lines. Multiline — Vercel and
#   most env managers accept it as-is.
# APNS_KEY_ID: 10-char key id shown next to the key in Apple Developer.
# APNS_TEAM_ID: 10-char Apple Developer team id (Membership details).
# APNS_BUNDLE_ID: iOS app bundle id used as the apns-topic header
#   (matches PRODUCT_BUNDLE_IDENTIFIER in the Xcode project).
# APNS_USE_SANDBOX (optional, default off): set to "1" only for local
#   Xcode dev-signed builds. TestFlight + App Store builds use the
#   production endpoint, so leave this unset in Vercel.
APNS_AUTH_KEY_P8=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=
